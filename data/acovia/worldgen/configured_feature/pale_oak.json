        "Name": "minecraft:pale_oak_leaves",
        "Properties": {
          "distance": "7",
          "persistent": "false",
          "waterlogged": "false"
        }
      }
    },
    "ignore_vines": true,
    "minimum_size": {
      "type": "minecraft:three_layers_feature_size",
